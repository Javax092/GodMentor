generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GoalCategory {
  PERSONAL
  PROFESSIONAL
  HEALTH
  STUDIES
  FINANCIAL
  RELATIONSHIPS
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum GoalPriority {
  LOW
  MEDIUM
  HIGH
}

enum InsightType {
  DAILY
  WEEKLY
  MONTHLY
  DAILY_SUMMARY
  ALERT
  PATTERN
  POSITIVE_PRESSURE
  RECOMMENDATION
  WEEKLY_REVIEW
}

enum PillarKey {
  EXECUTION
  SALES_NETWORKING
  BODY
  LEARNING
  REPUTATION
  DISCIPLINE
  REFLECTION
}

enum MissionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum XpSource {
  CHALLENGE
  STREAK
  STUDY
  TRAINING
  SALES
  CONTENT
  NIGHT_CHECKIN
  WEEKLY_REVIEW
  FOCUS
  GOAL
}

enum StreakType {
  DAILY
  FOCUS
  CHECKIN
}

enum SubscriptionTier {
  FREE
  PRO
  ELITE
}

model User {
  id                 String               @id @default(cuid())
  name               String
  email              String               @unique
  passwordHash       String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  subscriptionTier   SubscriptionTier     @default(FREE)
  subscriptionPlanId String?
  journalEntries     JournalEntry[]
  goals              Goal[]
  weeklyReviews      WeeklyReview[]
  monthlyReviews     MonthlyReview[]
  aiInsights         AiInsight[]
  dailyMissions      DailyMission[]
  checkIns           CheckIn[]
  focusSessions      FocusSession[]
  xpEvents           XpEvent[]
  streaks            Streak[]
  achievements       UserAchievement[]
  subscriptionPlan   SubscriptionPlan?    @relation(fields: [subscriptionPlanId], references: [id], onDelete: SetNull)
}

model JournalEntry {
  id               String   @id @default(cuid())
  userId           String
  date             DateTime
  score            Int
  mood             String
  content          String
  win              String
  challenge        String
  tomorrowPriority String
  gratitude        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model Goal {
  id          String       @id @default(cuid())
  userId      String
  pillarId    String?
  title       String
  description String
  category    GoalCategory
  period      GoalPeriod
  deadline    DateTime?
  progress    Int          @default(0)
  status      GoalStatus   @default(ACTIVE)
  priority    GoalPriority @default(MEDIUM)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pillar      Pillar?      @relation(fields: [pillarId], references: [id], onDelete: SetNull)

  @@index([userId, status, period])
  @@index([pillarId])
}

model WeeklyReview {
  id           String   @id @default(cuid())
  userId       String
  weekStart    DateTime
  worked       String
  didntWork    String
  lesson       String
  obstacle     String
  nextFocus    String
  wins         String?
  failures     String?
  patterns     String?
  aiSummary    String?
  score        Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
}

model MonthlyReview {
  id              String   @id @default(cuid())
  userId          String
  month           DateTime
  biggestGrowth   String
  completedGoals  String
  helpfulHabits   String
  harmfulHabits   String
  nextMonthFocus  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
}

model AiInsight {
  id        String      @id @default(cuid())
  userId    String
  type      InsightType
  title     String?
  content   String
  strength  Int?
  metadata  Json?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
}

model Pillar {
  id          String         @id @default(cuid())
  key         PillarKey      @unique
  name        String
  description String
  icon        String
  color       String
  order       Int
  missions    Mission[]
  dailyItems  DailyMission[]
  goals       Goal[]
}

model Mission {
  id          String      @id @default(cuid())
  pillarId    String
  slug        String      @unique
  title       String
  description String
  xpReward    Int
  isActive    Boolean     @default(true)
  order       Int
  pillar      Pillar      @relation(fields: [pillarId], references: [id], onDelete: Cascade)
  dailyItems  DailyMission[]

  @@index([pillarId, order])
}

model DailyMission {
  id          String        @id @default(cuid())
  userId      String
  pillarId    String
  missionId   String
  date        DateTime
  status      MissionStatus @default(PENDING)
  progress    Int           @default(0)
  xpEarned    Int           @default(0)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pillar      Pillar        @relation(fields: [pillarId], references: [id], onDelete: Cascade)
  mission     Mission       @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId, date])
  @@index([userId, date])
}

model CheckIn {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime
  advanced        String
  failed          String
  improveTomorrow String
  energy          Int
  mood            String
  dayScore        Int
  sleepHours      Float?
  aiSummary       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model FocusSession {
  id              String   @id @default(cuid())
  userId          String
  startedAt       DateTime
  endedAt         DateTime?
  durationMinutes Int
  category        String?
  notes           String?
  xpEarned        Int      @default(0)
  isCompleted     Boolean  @default(false)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

model XpEvent {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  source      XpSource
  description String
  referenceId String?
  metadata    Json?
  occurredAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([userId, source])
}

model Streak {
  id           String     @id @default(cuid())
  userId       String
  type         StreakType
  currentValue Int        @default(0)
  bestValue    Int        @default(0)
  lastActiveAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId, type])
}

model Level {
  id        String   @id @default(cuid())
  rank      Int      @unique
  name      String
  minXp     Int      @unique
  createdAt DateTime @default(now())
}

model Achievement {
  id            String            @id @default(cuid())
  key           String            @unique
  title         String
  description   String
  icon          String
  xpBonus       Int               @default(0)
  requirement   String
  requirementPk String?
  users         UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, unlockedAt])
}

model SubscriptionPlan {
  id                    String            @id @default(cuid())
  tier                  SubscriptionTier  @unique
  name                  String
  description           String
  pillarsLimit          Int?
  dashboardLimit        Int?
  hasFullAiMentor       Boolean           @default(false)
  hasAdvancedAnalytics  Boolean           @default(false)
  hasAdvancedGoals      Boolean           @default(false)
  hasVoiceAi            Boolean           @default(false)
  hasAutomation         Boolean           @default(false)
  hasPremiumReports     Boolean           @default(false)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  users                 User[]
}
